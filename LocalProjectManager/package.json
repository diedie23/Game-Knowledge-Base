    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.368.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
